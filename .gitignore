# ─── Secrets & credentials — NEVER commit these ───────────────────
.streamlit/secrets.toml
secrets.toml
token.json
token_ads.json
credentials.json
client_secret.json
*sk-proj-*          # stray OpenAI key files
*.pem
*.key

# ─── Generated / runtime output ───────────────────────────────────
narrative_output.json

# ─── Audit evidence bundles (T2) — full client account data ───────
# The tool streams these straight to a PRIVATE Drive folder and never writes one to disk.
# These patterns are the backstop: a bundle dumped locally for debugging must never be
# committable.
*.json.gz
evidence_*.json

# ─── Internal resource IDs (feedback Form / responses Sheet) ──────
feedback_config.json

# ─── Python ───────────────────────────────────────────────────────
__pycache__/
*.pyc

# ─── macOS ────────────────────────────────────────────────────────
.DS_Store

# ─── Client data & big files — keep LOCAL only, never commit ──────
*.pdf
*.pptx
*.ppt
*.key
*.docx
sample_audits/

# Local-only narrative eval harness (loads secrets at runtime — never push)
_local_eval/
